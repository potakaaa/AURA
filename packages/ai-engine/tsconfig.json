{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "composite": false
  },
  "include": ["*.ts", "prompts/**/*", "context/**/*"],
  "exclude": ["node_modules", "dist"]
}
