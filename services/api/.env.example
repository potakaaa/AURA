# Runtime mode used by CORS logic in src/app.ts.
# Values: development | production
NODE_ENV=development

# HTTP port used by src/index.ts when starting the Hono server.
PORT=3000

# Reported by GET /health as the API version string.
APP_VERSION=0.1.0

# Comma-separated allowed origins when NODE_ENV=production.
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://app.example.com

# Google OAuth client ID from Google Cloud Console credentials.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google OAuth client secret from Google Cloud Console credentials.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URI configured on your Google OAuth client.
# Example (mobile deep link): aura://oauth2redirect/google
GOOGLE_REDIRECT_URI=aura://oauth2redirect/google

# OAuth scopes requested for MVP.
# Keep as minimal identity scopes until W7 integration scopes are introduced.
GOOGLE_OAUTH_SCOPES=openid email profile

# Optional override for Google token endpoint (useful in tests).
GOOGLE_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token

# Optional override for Google OpenID userinfo endpoint.
GOOGLE_USERINFO_ENDPOINT=https://openidconnect.googleapis.com/v1/userinfo

# SQLite database path for storing auth sessions and Google tokens.
AUTH_DB_PATH=./.data/auth.db

# Milliseconds before expiry when access tokens are treated as expired.
AUTH_ACCESS_TOKEN_EXPIRY_SKEW_MS=30000
